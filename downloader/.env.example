# Copia a .env y completa. NO subas .env ni sa-key.json a git.

# Secreto compartido. Debe coincidir con LOCAL_DOWNLOADER_TOKEN en el orquestador.
# Genera uno largo, p.ej.:  python -c "import secrets;print(secrets.token_urlsafe(32))"
VIGIA_DL_TOKEN=

# Token del túnel Cloudflare (OPCIÓN A). Lo da el dashboard al crear el túnel.
# Si usas el túnel rápido (OPCIÓN B), deja esto vacío.
TUNNEL_TOKEN=

# Bucket y proyecto (defaults ya correctos para Vigía).
GCS_BUCKET=vigia-peru-documentos
GCP_PROJECT=vivid-spot-480905-a4

# Tope por documento (bytes). 60 MB por defecto.
MAX_BYTES=62914560
