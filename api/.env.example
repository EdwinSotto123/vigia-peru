# ─── Cloud SQL Postgres ────────────────────────────────────────
# Para dev local con Cloud SQL Auth Proxy:
#   cloud-sql-proxy --port 5432 vivid-spot-480905-a4:us-central1:vigia-db
# Y en este archivo:
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=<reemplazar con el de .cloudsql-password>
PGDATABASE=vigia

# Para Cloud Run en producción, usá variables del entorno + Unix socket:
# PGHOST=/cloudsql/vivid-spot-480905-a4:us-central1:vigia-db

# ─── GCS buckets ──────────────────────────────────────────────
GCS_BUCKET_DOCUMENTOS=vigia-peru-documentos
GCS_BUCKET_REPORTES=vigia-peru-reportes
GCS_PROJECT_ID=vivid-spot-480905-a4

# ─── Firebase Admin (para validar ID tokens del frontend) ────
FIREBASE_PROJECT_ID=simplia-project
# Acceso a Application Default Credentials (gcloud auth application-default login)
# o pegá el JSON de service-account aquí en GOOGLE_APPLICATION_CREDENTIALS_JSON

# ─── Server ──────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000,https://vigia-peru.vercel.app
